<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.READ_CALENDAR" />

    <application
        android:name=".CalendarArchiveApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CalendarArchive"
        tools:targetApi="35">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.CalendarArchive">

            <!-- Launcher intent (default app icon) -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Calendar time URI handler — appears in "Open with" chooser
                 when CalendarAlarm (or any app) opens content://com.android.calendar/time/... -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data
                    android:scheme="content"
                    android:host="com.android.calendar"
                    android:pathPrefix="/time" />
            </intent-filter>

        </activity>

        <activity
            android:name=".SourceCalendarsActivity"
            android:exported="false"
            android:label="@string/title_source_calendars"
            android:theme="@style/Theme.CalendarArchive" />

    </application>

</manifest>
