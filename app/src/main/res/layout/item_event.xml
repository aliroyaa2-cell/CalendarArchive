<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/itemRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface_card_dark"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    android:padding="12dp"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <!-- Color stripe on the left -->
    <View
        android:id="@+id/colorStripe"
        android:layout_width="4dp"
        android:layout_height="0dp"
        android:background="@color/accent_blue"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:textColor="@color/text_primary_dark"
        android:textSize="16sp"
        android:textStyle="bold"
        android:maxLines="2"
        android:ellipsize="end"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/colorStripe"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="عنوان الحدث" />

    <!-- Time -->
    <TextView
        android:id="@+id/tvTime"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="4dp"
        android:textColor="@color/accent_blue"
        android:textSize="13sp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toEndOf="@id/colorStripe"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="2025-01-15 - الساعة 10:00 ص" />

    <!-- Source name -->
    <TextView
        android:id="@+id/tvSource"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="2dp"
        android:textColor="@color/text_secondary_dark"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/tvTime"
        app:layout_constraintStart_toEndOf="@id/colorStripe"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Google · personal@gmail.com" />

</androidx.constraintlayout.widget.ConstraintLayout>
